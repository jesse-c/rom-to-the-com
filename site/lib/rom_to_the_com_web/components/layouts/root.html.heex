<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content={RomToTheComWeb.Layouts.description()} />
    <link rel="icon" sizes="any" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={RomToTheComWeb.Layouts.canonical_url()} />
    <meta property="og:title" content={"Rom-to-the-Com · #{assigns[:page_title]}"} />
    <meta property="og:description" content={RomToTheComWeb.Layouts.description()} />
    <meta property="og:url" content={RomToTheComWeb.Layouts.canonical_url()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rom-to-the-Com" />
    <meta name="twitter:card" content="summary" />
    <.live_title prefix="Rom-to-the-Com · ">
      {assigns[:page_title]}
    </.live_title>
    <script type="application/ld+json">
      <%= RomToTheComWeb.Layouts.schema_markup() %>
    </script>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script
      defer
      data-domain={Application.get_env(:rom_to_the_com, RomToTheCom.Plausible)[:data_domain]}
      src="https://plausible.io/js/script.js"
    >
    </script>
  </head>
  <body class="bg-white dark:bg-black text-black dark:text-white font-inter">
    {@inner_content}
  </body>
</html>
